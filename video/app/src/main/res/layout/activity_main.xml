<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Video Downloader"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2c3e50"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download videos from YouTube, TikTok, Instagram, Facebook"
            android:textSize="14sp"
            android:textColor="#7f8c8d"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- URL Input Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video URL"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2c3e50"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etVideoUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Paste video URL here..."
                android:inputType="textUri"
                android:maxLines="3"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColorHint="#7f8c8d" />

        </LinearLayout>

        <!-- Platform Selection Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supported Platforms"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2c3e50"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📹 YouTube"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="#e8f4fd"
                    android:textColor="#2980b9"
                    android:layout_margin="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎵 TikTok"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="#fce8e8"
                    android:textColor="#c0392b"
                    android:layout_margin="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📷 Instagram"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="#f8e8ff"
                    android:textColor="#8e44ad"
                    android:layout_margin="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👥 Facebook"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="#e8f6ff"
                    android:textColor="#2980b9"
                    android:layout_margin="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Quality Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Quality"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2c3e50"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerQuality"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:padding="12dp" />

        </LinearLayout>

        <!-- Download Button -->
        <Button
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Download Video"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#27ae60"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"
            android:drawableLeft="@android:drawable/stat_sys_download"
            android:drawablePadding="8dp"
            android:gravity="center" />

        <!-- Progress Card -->
        <LinearLayout
            android:id="@+id/progressCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tvDownloadStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Downloading..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2c3e50"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="?android:attr/progressBarStyleHorizontal"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:textColor="#7f8c8d"
                android:layout_gravity="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#fff3cd"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️ How to use:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#856404"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Copy the video URL from your favorite platform\n2. Paste it in the URL field above\n3. Select your preferred quality\n4. Tap Download Video\n5. Videos will be saved to Downloads folder"
                android:textSize="12sp"
                android:textColor="#856404"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>